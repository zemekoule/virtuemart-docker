# Verze Joomla a PHP (viz https://hub.docker.com/_/joomla/tags)
# Dostupné kombinace jsou např. 5-php8.3-apache, 5-php8.2-apache, 4-php8.1-apache
JOOMLA_TAG=5
PHP_VERSION=8.3

# UID/GID pro www-data uvnitř kontejneru — sjednotit s hostitelem
# Linux: zjisti přes `id -u` a `id -g` (typicky 1000:1000)
# macOS: typicky 501:20 (zjisti přes `id -u` a `id -g`)
ENV_UID=1000
ENV_GID=1000

# Joomla auto-install (oficiální image proběhne sám při prvním startu)
JOOMLA_SITE_NAME=VirtueMart Dev
JOOMLA_ADMIN_USER=Admin
JOOMLA_ADMIN_USERNAME=admin
JOOMLA_ADMIN_PASSWORD=adminadmin12
JOOMLA_ADMIN_EMAIL=admin@example.com
